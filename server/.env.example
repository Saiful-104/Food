# Backend Environment Variables

# Port Configuration
PORT=5000

# Database Configuration
# MongoDB URI - Update with your MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/foodexpress?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Environment
NODE_ENV=production

# CORS Configuration - Update with your frontend URL
CLIENT_URL=https://your-frontend-url.vercel.com

# File Upload (if using Cloudinary or similar)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (if implementing email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Payment Gateway (if implementing payments)
# STRIPE_PUBLIC_KEY=pk_live_xxxxxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxxxxx

# Logging
# LOG_LEVEL=info
